{
  "$schema": "../schema/case.schema.json",
  "schemaVersion": "0.1",
  "id": "source.parse.static-visuals",
  "title": "Parse static visual fences and native visual nodes losslessly",
  "description": "Canonical Mermaid and Vega-Lite fences remain inert code blocks while native diagrams and charts retain asset references.",
  "status": "active",
  "area": "source-parse",
  "tags": ["mermaid", "vega-lite", "visuals"],
  "specReferences": [
    "NotMarkdown-v0.1-Draft.md static visual notation"
  ],
  "operation": {
    "name": "parse-source"
  },
  "input": {
    "fixtures": [
      {
        "role": "source",
        "path": "conformance/fixtures/source/static-visuals.nmt",
        "mediaType": "text/x-notmarkdown"
      },
      {
        "role": "schema",
        "path": "notmarkdown-cdm-0.1.schema.json",
        "mediaType": "application/schema+json"
      }
    ]
  },
  "expected": {
    "outcome": "accepted",
    "assertions": [
      {
        "operator": "array-length",
        "pointer": "/diagnostics",
        "value": 0
      },
      {
        "operator": "equals",
        "pointer": "/document/children/1/type",
        "value": "codeBlock"
      },
      {
        "operator": "equals",
        "pointer": "/document/children/1/language",
        "value": "mermaid"
      },
      {
        "operator": "equals",
        "pointer": "/document/children/2/language",
        "value": "vega-lite"
      },
      {
        "operator": "equals",
        "pointer": "/document/children/3/language",
        "value": "vegalite"
      },
      {
        "operator": "equals",
        "pointer": "/document/children/4/source/id",
        "value": "architecture"
      },
      {
        "operator": "equals",
        "pointer": "/document/children/5/data/id",
        "value": "latency"
      },
      {
        "operator": "matches-schema",
        "pointer": "/document",
        "value": "notmarkdown-cdm-0.1.schema.json"
      }
    ]
  }
}
