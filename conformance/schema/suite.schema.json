{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:notmarkdown:conformance:suite:0.1",
  "title": "NotMarkdown conformance suite 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "name",
    "defaultStatuses",
    "cases"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "0.1" },
    "name": { "type": "string", "minLength": 1 },
    "defaultStatuses": {
      "type": "array",
      "items": { "enum": ["active", "draft"] },
      "uniqueItems": true
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^conformance/cases/[a-z0-9.-]+\\.case\\.json$"
      },
      "uniqueItems": true
    }
  }
}

