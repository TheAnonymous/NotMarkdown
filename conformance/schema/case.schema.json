{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:notmarkdown:conformance:case:0.1",
  "title": "NotMarkdown conformance case 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "title",
    "status",
    "area",
    "operation",
    "input",
    "expected"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "0.1" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "status": { "enum": ["active", "draft"] },
    "area": {
      "enum": [
        "source-parse",
        "markdown-import",
        "package-read",
        "package-write",
        "determinism",
        "security"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "specReferences": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "enum": [
            "parse-source",
            "import-markdown",
            "open-package",
            "create-package",
            "verify-package",
            "compare-package-builds"
          ]
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixtures"],
      "properties": {
        "fixtures": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fixture" }
        },
        "mutations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/mutation" }
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "assertions"],
      "properties": {
        "outcome": { "enum": ["accepted", "rejected"] },
        "assertions": {
          "type": "array",
          "items": { "$ref": "#/$defs/assertion" }
        }
      }
    },
    "notes": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "mediaType"],
      "properties": {
        "role": {
          "enum": ["input", "source", "package", "asset", "schema"]
        },
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "bytesBase64": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/]*={0,2}$"
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
        },
        "mediaType": { "type": "string", "minLength": 3 },
        "dialect": { "type": "string", "minLength": 1 },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "oneOf": [
        {
          "properties": { "path": true },
          "required": ["path"],
          "not": {
            "properties": { "bytesBase64": true },
            "required": ["bytesBase64"]
          }
        },
        {
          "properties": { "bytesBase64": true },
          "required": ["bytesBase64"],
          "not": {
            "properties": { "path": true },
            "required": ["path"]
          }
        }
      ]
    },
    "mutation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": [
            "flip-entry-payload-byte",
            "append-duplicate-entry",
            "append-unsafe-path-entry"
          ]
        },
        "entry": { "type": "string", "minLength": 1 },
        "offset": { "type": "integer", "minimum": 0 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator", "pointer", "value"],
      "properties": {
        "operator": {
          "enum": [
            "equals",
            "not-equals",
            "array-length",
            "contains-code",
            "matches-schema"
          ]
        },
        "pointer": {
          "type": "string",
          "pattern": "^(?:|(?:/(?:[^~/]|~[01])*)+)$"
        },
        "value": true,
        "description": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "operator": { "const": "array-length" } }
          },
          "then": {
            "properties": { "value": { "type": "integer", "minimum": 0 } }
          }
        },
        {
          "if": {
            "properties": {
              "operator": { "enum": ["contains-code", "matches-schema"] }
            }
          },
          "then": {
            "properties": { "value": { "type": "string", "minLength": 1 } }
          }
        }
      ]
    }
  }
}
