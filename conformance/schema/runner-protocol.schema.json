{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:notmarkdown:conformance:runner-protocol:0.1",
  "title": "NotMarkdown conformance runner protocol 0.1",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/response" }
  ],
  "$defs": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "kind", "requestId", "operation"],
      "properties": {
        "protocolVersion": { "const": "0.1" },
        "kind": { "const": "request" },
        "requestId": { "type": "string", "minLength": 1 },
        "operation": {
          "enum": [
            "capabilities",
            "parse-source",
            "import-markdown",
            "open-package",
            "create-package",
            "verify-package",
            "compare-package-builds"
          ]
        },
        "fixtures": {
          "type": "array",
          "items": { "$ref": "#/$defs/resolvedFixture" }
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocolVersion",
        "kind",
        "requestId",
        "status",
        "outcome",
        "diagnostics",
        "data"
      ],
      "properties": {
        "protocolVersion": { "const": "0.1" },
        "kind": { "const": "response" },
        "requestId": { "type": "string", "minLength": 1 },
        "status": { "enum": ["completed", "unsupported", "error"] },
        "outcome": { "enum": ["accepted", "rejected", "not-run"] },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "message"],
          "properties": {
            "kind": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "resolvedFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "path", "mediaType"],
      "properties": {
        "role": {
          "enum": ["input", "source", "package", "asset", "schema", "output"]
        },
        "path": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "mediaType": { "type": "string", "minLength": 3 },
        "dialect": { "type": "string", "minLength": 1 }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": true,
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["error", "warning", "info"] },
        "message": { "type": "string" },
        "range": {
          "type": "object",
          "additionalProperties": false,
          "required": ["start", "end"],
          "properties": {
            "start": { "$ref": "#/$defs/position" },
            "end": { "$ref": "#/$defs/position" }
          }
        },
        "suggestion": { "type": "string" }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "column"],
      "properties": {
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      }
    }
  }
}

